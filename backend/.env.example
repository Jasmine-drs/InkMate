# 应用配置
APP_NAME=AI Novel Writing Assistant
DEBUG=True

# 数据库配置
DATABASE_URL=mysql+aiomysql://root:rootpass@localhost:3306/novel_db

# Redis 配置
REDIS_URL=redis://localhost:6379

# Milvus 向量数据库配置
MILVUS_HOST=localhost
MILVUS_PORT=19530

# JWT 配置 (生产环境请修改)
SECRET_KEY=your-super-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# AI 模型配置
